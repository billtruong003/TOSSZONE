# Unity generated / caches
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Visual Studio / Rider / IDE
.vs/
.vscode/
.idea/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Packaged asset bundles
/[Aa]ssets/[Aa]ssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*

# OS
.DS_Store
Thumbs.db

# Paid Asset Store assets — NOT redistributed publicly (re-import from the Asset Store after cloning)
/[Aa]ssets/AutoHand/
/[Aa]ssets/AutoHand.meta

# Unity auto-generated crash/scene recovery (local only)
/[Aa]ssets/_Recovery/
/[Aa]ssets/_Recovery.meta

# Owner's proprietary shader kit — resolved via the UPM git dependency in manifest.json (self-heals on clone).
# This ignore only covers an OPTIONAL local embed of the same package under Packages/ (for in-place shader editing);
# the embedded copy is never committed (proprietary; this repo is public). Fresh clones get it from the git dependency.
/[Pp]ackages/com.billtruong.stylized-toon-world-kit/
/[Aa]ssets/StylizedToonWorldKit/
/[Aa]ssets/StylizedToonWorldKit.meta

# Local Meta XR embeds (downloaded as tarballs to work around UnityTls failing the Oculus registry).
# Pinned to 81.0.1 so the Meta XR Simulator works; not committed (large native libs, machine-local workaround).
/[Pp]ackages/com.meta.xr.sdk.core/
/[Pp]ackages/com.meta.xr.simulator/

# Claude Code Unity MCP config — machine-specific absolute uvx path; recreate per machine (template in HANDOFF).
/.mcp.json

# Meta Immersive Debugger (DevAgent) — auto-generated LAN debug token, regenerated each session (machine-local secret).
/[Aa]ssets/[Rr]esources/DevAgentSettings.asset

# Native build temp (CMake RelWithDebInfo / tools) — local build artifacts.
/.utmp/
