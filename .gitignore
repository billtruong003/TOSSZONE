# Unity generated / caches
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Visual Studio / Rider / IDE
.vs/
.vscode/
.idea/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Packaged asset bundles
/[Aa]ssets/[Aa]ssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*

# OS
.DS_Store
Thumbs.db

# Paid Asset Store assets — NOT redistributed publicly (re-import from the Asset Store after cloning)
/[Aa]ssets/AutoHand/
/[Aa]ssets/AutoHand.meta

# Unity auto-generated crash/scene recovery (local only)
/[Aa]ssets/_Recovery/
/[Aa]ssets/_Recovery.meta

# Owner's proprietary shader kit (com.billtruong.stylized-toon-world-kit) — embedded under Packages/ for in-place shader/material editing.
# Gitignored like AutoHand (proprietary; not redistributed). If a fresh clone is missing it, re-embed from
# github.com/billtruong003/stylized-toon-world-kit (or Tools ▸ TOSSZONE ▸ Install Stylized Toon World Kit for a read-only git fallback).
/[Pp]ackages/com.billtruong.stylized-toon-world-kit/
/[Aa]ssets/StylizedToonWorldKit/
/[Aa]ssets/StylizedToonWorldKit.meta

# Claude Code Unity MCP config — machine-specific absolute uvx path; recreate per machine (template in HANDOFF).
/.mcp.json
